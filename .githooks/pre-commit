#!/usr/bin/env bash
# Pre-commit hook: reject lsts_hover/definition/diagnostics calls without a fixture file

set -euo pipefail

violations=$(git diff --cached --name-only | grep '_tests.bats$' | while read -r f; do
    awk '
    /lsts_hover[[:space:]]*\\|lsts_definition[[:space:]]*\\|lsts_diagnostics[[:space:]]/ {
        call_line = NR
        fname = FILENAME
        has_fixture = 0
    }
    /fixtures\// {
        if (NR <= call_line + 5) has_fixture = 1
    }
    /^[[:space:]]*\}/ {
        if (call_line > 0 && !has_fixture) {
            print fname ":" call_line ": lsts call missing fixture file (snapshot mode not allowed)"
        }
        call_line = 0
    }
    ' "$f"
done)

if [[ -n "$violations" ]]; then
    echo "ERROR: snapshot mode detected — all lsts_hover/definition/diagnostics calls must have a fixture file:" >&2
    echo "$violations" >&2
    exit 1
fi
