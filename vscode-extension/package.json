{
  "name": "anakins-dtls",
  "displayName": "anakins-dtls",
  "description": "Device Tree Language Server",
  "version": "0.0.1",
  "publisher": "anakin4747",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:dts"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "dts",
        "aliases": ["Device Tree", "dts"],
        "extensions": [".dts", ".dtsi"]
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0",
    "esbuild": "^0.20.0"
  }
}
