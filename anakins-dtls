handle_rename() {
    local body="$1"
    local uri lnum character id new_name text
    uri=$(printf '%s' "$body" | jq -r '.params.textDocument.uri')
    lnum=$(printf '%s' "$body" | jq -r '.params.position.line')
    character=$(printf '%s' "$body" | jq -r '.params.position.character')
    id=$(printf '%s' "$body" | jq -r '.id')
    new_name=$(printf '%s' "$body" | jq -r '.params.newName')
    text="${DOC_TEXT[$uri]:-}"

    if [[ -z "$text" ]]; then
        send "$(jq -n --argjson id "$id" '{"jsonrpc":"2.0","id":$id,"result":null}')"
        return
    fi

    local label=""
    label="$(phandle_ref_at "$text" "$lnum" "$character")" || label=""
    if [[ -z "$label" ]]; then
        local line_text
        line_text="$(printf '%s' "$text" | sed -n "$((lnum + 1))p")"
        if [[ "$line_text" =~ ^[[:space:]]*([A-Za-z_][A-Za-z0-9_]*)[[:space:]]*: ]]; then
            label="${BASH_REMATCH[1]}"
        fi
    fi

    if [[ -z "$label" ]]; then
        send "$(jq -n --argjson id "$id" '{"jsonrpc":"2.0","id":$id,"result":null}')"
        return
    fi

    local file_path="${uri#file://}"
    local -a all_files=()
    mapfile -t all_files < <(
        find_includers_of "$file_path" "$(dirname "$file_path")" 2>/dev/null
        printf '%s\n' "$file_path"
    )
    mapfile -t all_files < <(printf '%s\n' "${all_files[@]}" | sort -u)

    local changes_json="{}"
    local f
    for f in "${all_files[@]}"; do
        [[ -z "$f" || ! -f "$f" ]] && continue
        local file_edits
        file_edits="$(_collect_rename_edits "$f" "$label" "$new_name")"
        [[ "$file_edits" == "[]" ]] && continue
        local file_uri="file://$f"
        changes_json="$(printf '%s' "$changes_json" | jq --arg uri "$file_uri" --argjson edits "$file_edits" '. + {($uri): $edits}')"
    done

    send "$(jq -n --argjson id "$id" --argjson changes "$changes_json" '{"jsonrpc":"2.0","id":$id,"result":{"changes":$changes}}')"
}

_collect_rename_edits() {
    local file="$1" old_label="$2" new_label="$3"
    local -a edits_arr=()
    local lineno=0
    while IFS= read -r raw_line; do
        # Match label definition: word: ...
        if [[ "$raw_line" =~ ^([[:space:]]*)${old_label}[[:space:]]*: ]]; then
            local col="${#BASH_REMATCH[1]}"
            edits_arr+=("$(jq -n \
                --argjson l "$lineno" --argjson cs "$col" --argjson ce "$((col + ${#old_label}))" \
                --arg t "$new_label" \
                '{"range":{"start":{"line":$l,"character":$cs},"end":{"line":$l,"character":$ce}},"newText":$t}')")
        fi
        # Match &label references on this line
        local rest="$raw_line" offset=0
        while [[ "$rest" =~ \&${old_label}([^A-Za-z0-9_]|$) ]]; do
            local before_amp="${rest%%\&${old_label}*}"
            local col=$((offset + ${#before_amp}))
            edits_arr+=("$(jq -n \
                --argjson l "$lineno" --argjson cs "$col" --argjson ce "$((col + 1 + ${#old_label}))" \
                --arg t "&${new_label}" \
                '{"range":{"start":{"line":$l,"character":$cs},"end":{"line":$l,"character":$ce}},"newText":$t}')")
            offset=$((col + 1 + ${#old_label}))
            rest="${raw_line:$offset}"
        done
        (( lineno++ )) || true
    done < "$file"
    local out="[" first=1 e
    for e in "${edits_arr[@]:-}"; do
        [[ -z "$e" ]] && continue
        [[ $first -eq 1 ]] || out+=","
        out+="$e"
        first=0
    done
    out+="]"
    printf '%s' "$out"
}

declare -A DOC_TEXT

# Resolve Linux kernel source directory from the workspace root path.
# Tries several well-known subdirectory layouts, then walks up the tree.
_resolve_linux_dir() {
    local root_path="$1"
    if [[ -d "${root_path}/tests/linux/Documentation/devicetree/bindings" ]]; then
        BINDINGS_DIR="${root_path}/tests/linux/Documentation/devicetree/bindings"
        LINUX_DIR="${root_path}/tests/linux"
    elif [[ -d "${root_path}/linux/Documentation/devicetree/bindings" ]]; then
        BINDINGS_DIR="${root_path}/linux/Documentation/devicetree/bindings"
        LINUX_DIR="${root_path}/linux"
    elif [[ -d "${root_path}/Documentation/devicetree/bindings" ]]; then
        BINDINGS_DIR="${root_path}/Documentation/devicetree/bindings"
        LINUX_DIR="${root_path}"
    else
        local _linux_root
        _linux_root="$(_find_linux_root "$root_path")" || _linux_root=""
        if [[ -n "$_linux_root" ]]; then
            BINDINGS_DIR="${_linux_root}/Documentation/devicetree/bindings"
            LINUX_DIR="$_linux_root"
        else
            BINDINGS_DIR="${root_path}/tests/linux/Documentation/devicetree/bindings"
            LINUX_DIR="${root_path}/tests/linux"
        fi
    fi
}

# Populate SPEC_DIR and INCLUDE_DIRS from the workspace root path.
_resolve_spec_and_includes() {
    local root_path="$1"
    if [[ -d "${root_path}/tests/devicetree-specification/source" ]]; then
        SPEC_DIR="${root_path}/tests/devicetree-specification/source"
    else
        SPEC_DIR="${root_path}/devicetree-specification/source"
    fi
    INCLUDE_DIRS=()
    local _idir
    for _idir in \
        "${LINUX_DIR}/include" \
        "${LINUX_DIR}/arch/arm/include" \
        "${LINUX_DIR}/arch/arm64/include" \
        "${root_path}/tests/linux/include" \
        "${root_path}/linux/include"; do
        [[ -d "$_idir" ]] && INCLUDE_DIRS+=("$_idir")
    done
}

# Kill all background jobs when the server exits.
trap 'kill $(jobs -p) 2>/dev/null || true' EXIT

# ---------------------------------------------------------------------------

while recv; do
    parse_request

    case "$method" in
        initialize)
            root_uri="$(printf '%s' "$BODY" | jq -r '.params.rootUri // .params.workspaceFolders[0].uri // ""')"
            root_path="${root_uri#file://}"
            _resolve_linux_dir "$root_path"
            _resolve_spec_and_includes "$root_path"
            send "{\"jsonrpc\":\"2.0\",\"id\":${id},\"result\":{\"capabilities\":{\"hoverProvider\":true,\"definitionProvider\":true,\"referencesProvider\":true,\"completionProvider\":{},\"documentSymbolProvider\":true,\"renameProvider\":true,\"textDocumentSync\":{\"openClose\":true,\"change\":1},\"diagnosticProvider\":{\"interFileDependencies\":false,\"workspaceDiagnostics\":false}}}}"
            ;;
        initialized)
            ;;
        textDocument/didOpen)
            text="$(printf '%s' "$BODY" | jq -r '.params.textDocument.text')"
            DOC_TEXT["$uri"]="$text"
            publish_diagnostics "$(jq -cn --arg u "$uri" '$u')" "$text"
            ;;
        textDocument/didChange)
            text="$(printf '%s' "$BODY" | jq -r '.params.contentChanges[-1].text')"
            DOC_TEXT["$uri"]="$text"
            publish_diagnostics "$(jq -cn --arg u "$uri" '$u')" "$text"
            ;;
        textDocument/hover)
            handle_hover "$id" "${DOC_TEXT["$uri"]:-}" "$line" "$character"
            ;;
        textDocument/definition)
            handle_definition "$BODY"
            ;;
        textDocument/references)
            handle_references "$BODY"
            ;;
        textDocument/completion)
            handle_completion "$BODY"
            ;;
        textDocument/documentSymbol)
            handle_document_symbols "$BODY"
            ;;
        textDocument/rename)
            handle_rename "$BODY"
            ;;
        shutdown)
            send "{\"jsonrpc\":\"2.0\",\"id\":${id},\"result\":null}"
            ;;
        exit)
            exit 0
            ;;
    esac
done

exit 0
