handle_document_symbols() {
    local body="$1"
    local uri id text
    uri=$(printf '%s' "$body" | jq -r '.params.textDocument.uri')
    id=$(printf '%s' "$body" | jq -r '.id')
    text="${DOC_TEXT[$uri]:-}"
    if [[ -z "$text" ]]; then
        send "$(jq -n --argjson id "$id" '{"jsonrpc":"2.0","id":$id,"result":[]}')"
        return
    fi
    local result
    result="$(_build_document_symbols "$text")"
    send "$(jq -n --argjson id "$id" --argjson result "$result" '{"jsonrpc":"2.0","id":$id,"result":$result}')"
}

# _build_document_symbols <text>
# Parse DTS document and return JSON array of DocumentSymbol objects.
_build_document_symbols() {
    local text="$1"
    # Use awk + jq to parse nodes/labels line-by-line
    # We build a tab-separated stream: lineno start_char end_char kind name detail open|close
    # Then post-process with jq to build the nested structure
    local flat_stream
    flat_stream="$(printf '%s' "$text" | awk '
    {
        lineno = NR - 1
        line = $0
        # strip // comments
        if (match(line, /\/\//)) line = substr(line, 1, RSTART-1)

        # count braces
        opens = 0; closes = 0
        for (i=1; i<=length(line); i++) {
            c = substr(line,i,1)
            if (c=="{") opens++
            else if (c=="}") closes++
        }

        # detect node line: optional label: name@addr { or label: name { or name@addr { or name {
        # regex: leading whitespace, optional label:, node-name[@addr], {
        if (match(line, /^([[:space:]]*)([A-Za-z_][A-Za-z0-9_,-]*:[ \t]*)?([A-Za-z_\/][A-Za-z0-9_,@\/.-]*)[ \t]*\{/)) {
            full = substr(line, RSTART, RLENGTH)
            # extract indent
            indent = ""
            for (k=1; k<=length(full); k++) {
                c = substr(full,k,1)
                if (c==" " || c=="\t") indent=indent c
                else break
            }
            col = length(indent)
            rest = substr(full, col+1)
            # Check for label:
            label = ""
            node_part = rest
            if (match(rest, /^([A-Za-z_][A-Za-z0-9_,-]*):[ \t]*/)) {
                matched = substr(rest, RSTART, RLENGTH)
                label = matched
                # strip colon and whitespace from label
                sub(/:[ \t]*$/, "", label)
                gsub(/[ \t]*$/, "", label)
                node_part = substr(rest, RSTART+RLENGTH)
            }
            # node_part is "name@addr {" or "name {"
            # extract node name and optional @addr
            node_name = ""
            unit_addr = ""
            if (match(node_part, /^([A-Za-z_\/][A-Za-z0-9_,@\/.-]*)/)) {
                full_name = substr(node_part, RSTART, RLENGTH)
                if (match(full_name, /@/)) {
                    node_name = substr(full_name, 1, RSTART-1)
                    unit_addr = substr(full_name, RSTART+1)
                } else {
                    node_name = full_name
                }
            }
            if (node_name != "" && node_name != "if" && node_name != "else" && node_name != "for") {
                if (unit_addr != "") {
                    detail = node_name "@" unit_addr
                } else {
                    detail = node_name
                }
                if (label != "") {
                    sym_name = label
                    kind = 8
                } else {
                    sym_name = node_name
                    kind = 5
                }
                sel_end = col + length(sym_name)
                print "OPEN\t" lineno "\t" col "\t" sel_end "\t" kind "\t" sym_name "\t" detail
            }
        }

        # emit CLOSE for each net closing brace
        net = closes - opens
        for (i=1; i<=net; i++) {
            print "CLOSE\t" lineno
        }
    }
    ')"

    # Now build nested JSON using jq
    printf '%s' "$flat_stream" | jq -Rn '
    def make_sym(entry):
        {
            name: entry.name,
            detail: entry.detail,
            kind: entry.kind,
            range: {start: {line: entry.start_line, character: 0}, end: {line: entry.end_line, character: 0}},
            selectionRange: {start: {line: entry.start_line, character: entry.start_char}, end: {line: entry.start_line, character: entry.end_char}},
            children: entry.children
        };
    [inputs] |
    reduce .[] as $tok (
        {stack: [], roots: []};
        if ($tok | startswith("OPEN\t")) then
            ($tok | split("\t")) as $parts |
            .stack += [{
                start_line: ($parts[1] | tonumber),
                start_char: ($parts[2] | tonumber),
                end_char: ($parts[3] | tonumber),
                kind: ($parts[4] | tonumber),
                name: $parts[5],
                detail: $parts[6],
                end_line: 0,
                children: []
            }]
        elif ($tok | startswith("CLOSE\t")) then
            ($tok | split("\t")) as $parts |
            if (.stack | length) > 0 then
                (.stack[-1] | . + {end_line: ($parts[1] | tonumber)}) as $entry |
                make_sym($entry) as $sym |
                .stack = .stack[:-1] |
                if (.stack | length) > 0 then
                    .stack[-1].children += [$sym]
                else
                    .roots += [$sym]
                end
            else . end
        else . end
    ) | .roots
    '
}

