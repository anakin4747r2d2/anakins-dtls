# Walk up directory tree to find the Linux source tree root.
_find_linux_root() {
    local p="$1"
    while [[ -n "$p" && "$p" != "/" ]]; do
        [[ -d "$p/Documentation/devicetree/bindings" ]] && { printf '%s' "$p"; return 0; }
        p="${p%/*}"
    done
    return 1
}



# Convert a rg "file:line:col" match into a Location JSON object string, or empty.
_match_to_location_json() {
    local match="$1"
    local ref_file _raw_line _raw_col ref_line ref_col
    ref_file="$(printf '%s' "$match" | cut -d: -f1)"
    _raw_line="$(printf '%s' "$match" | cut -d: -f2)"
    _raw_col="$(printf '%s' "$match" | cut -d: -f3)"
    [[ "$_raw_line" =~ ^[0-9]+$ ]] || return 0
    [[ "$_raw_col" =~ ^[0-9]+$ ]] || _raw_col=1
    ref_line=$(( _raw_line - 1 ))
    ref_col=$(( _raw_col - 1 ))
    [[ $ref_line -lt 0 ]] && ref_line=0
    [[ $ref_col -lt 0 ]] && ref_col=0
    printf '{"uri":"file://%s","range":{"start":{"line":%d,"character":%d},"end":{"line":%d,"character":%d}}}' \
        "$ref_file" "$ref_line" "$ref_col" "$ref_line" "$ref_col"
}

# Collect phandle references for a label across all related DTS/DTSI files.
# Outputs Location JSON strings, one per line.
_find_label_refs() {
    local label="$1" uri="$2" text="$3"
    local cur_file="${uri#file://}"
    local label_def_file same_line
    same_line="$(find_label_line "$text" "$label")" || same_line=""
    if [[ -n "$same_line" ]]; then
        label_def_file="$cur_file"
    else
        local cross
        cross="$(find_label_in_includes "$label" "$cur_file")" || cross=""
        label_def_file="${cross%:*}"
    fi
    [[ -z "$label_def_file" ]] && return 0
    [[ -z "${LINUX_DIR:-}" ]] && return 0
    local dts_file_list
    mapfile -t dts_file_list < <(
        find_includers_of "$label_def_file" "${LINUX_DIR}/arch" 2>/dev/null
        printf '%s\n' "$label_def_file"
        grep -oP '#include[[:space:]]+"\K[^"]+(?=.*\.(dts|dtsi))' "$cur_file" 2>/dev/null | while read -r inc; do
            [[ "$inc" = /* ]] && printf '%s\n' "$inc" || printf '%s\n' "$(dirname "$cur_file")/$inc"
        done
    )
    while IFS= read -r match; do
        local loc
        loc="$(_match_to_location_json "$match")"
        [[ -n "$loc" ]] && printf '%s\n' "$loc"
    done < <(printf '%s\n' "${dts_file_list[@]:-}" | grep -v '^$' | sort -u | xargs -r rg -H -n --column --only-matching -F "&${label}" 2>/dev/null)
}

handle_references() {
    local body="$1"
    local uri line character id text
    uri=$(printf '%s' "$body" | jq -r '.params.textDocument.uri')
    line=$(printf '%s' "$body" | jq -r '.params.position.line')
    character=$(printf '%s' "$body" | jq -r '.params.position.character')
    id=$(printf '%s' "$body" | jq -r '.id')
    text="${DOC_TEXT[$uri]:-}"
    [[ -z "$text" ]] && { send_null "$id"; return; }

    local word
    word="$(word_at "$text" "$line" "$character")"
    word="${word%%:*}"
    if [[ -z "$word" ]]; then
        send "$(jq -n --argjson id "$id" '{"jsonrpc":"2.0","id":$id,"result":[]}')"
        return
    fi

    local results=()

    if [[ -n "${LINUX_DIR:-}" ]]; then
        local pattern="" search_glob="" line_text
        line_text="$(printf '%s' "$text" | sed -n "$((line + 1))p")"

        if printf '%s' "$line_text" | grep -qE "^[[:space:]]*${word}[[:space:]]*:"; then
            local label_locs
            mapfile -t label_locs < <(_find_label_refs "$word" "$uri" "$text")
            results+=("${label_locs[@]:-}")
        elif printf '%s' "$line_text" | grep -q 'compatible.*='; then
            pattern="\"${word}\""
            search_glob="--glob=*.dts --glob=*.dtsi --glob=*.yaml --glob=*.c --glob=*.h"
        else
            pattern=" ${word}:"
            search_glob="--glob=*.yaml"
        fi

        while IFS= read -r match; do
            local loc
            loc="$(_match_to_location_json "$match")"
            [[ -n "$loc" ]] && results+=("$loc")
        done < <([[ -n "${search_glob:-}" && -n "${pattern:-}" ]] && rg -n --column "$pattern" $search_glob "$LINUX_DIR" 2>/dev/null || true)
    fi

    # Build and emit sorted, deduplicated results array
    local json_array first r
    first=1
    json_array="["
    for r in "${results[@]:-}"; do
        [[ -z "$r" ]] && continue
        [[ $first -eq 0 ]] && json_array="${json_array},"
        json_array="${json_array}${r}"
        first=0
    done
    json_array="${json_array}]"
    # Sort by URI for deterministic output
    local sorted_json
    sorted_json="$(printf '%s' "$json_array" | jq 'sort_by(.uri + (.range.start.line | tostring))' 2>/dev/null)" || sorted_json="$json_array"
    send "$(jq -n --argjson id "$id" --argjson refs "$sorted_json" '{"jsonrpc":"2.0","id":$id,"result":$refs}')"
}



handle_completion() {
    local body="$1"
    local uri line character id text
    uri=$(printf '%s' "$body" | jq -r '.params.textDocument.uri')
    line=$(printf '%s' "$body" | jq -r '.params.position.line')
    character=$(printf '%s' "$body" | jq -r '.params.position.character')
    id=$(printf '%s' "$body" | jq -r '.id')
    text="${DOC_TEXT[$uri]:-}"

    local items=() prop

    local std_props=(compatible reg status model device_type phandle
        "#address-cells" "#size-cells" ranges dma-ranges
        interrupts interrupt-parent "#interrupt-cells" interrupt-controller
        clocks clock-names "#clock-cells"
        resets reset-names "#reset-cells"
        gpios gpio-controller "#gpio-cells" gpio-ranges
        pinctrl-0 pinctrl-names
        dmas dma-names "#dma-cells"
        power-domains iommus
        reg-names label wakeup-source
        stdout-path bootargs)

    for prop in "${std_props[@]}"; do
        items+=("$(jq -n --arg l "$prop" '{"label":$l,"kind":10,"detail":"Standard DT property"}')")
    done

    if [[ -n "${BINDINGS_DIR:-}" ]]; then
        local compat=""
        # Find the current node boundaries: scan backward to find the opening {
        # then scan that entire block (forward too) for compatible =
        local node_start node_end total_lines
        total_lines="$(printf '%s' "$text" | wc -l)"
        # Walk backward from cursor to find where current node opens
        node_start="$(printf '%s' "$text" | awk -v cursor="$((line + 1))" '
            NR <= cursor {
                for (i=1;i<=length($0);i++) {
                    c=substr($0,i,1)
                    if (c=="{") depth++
                    else if (c=="}") depth--
                }
                lines[NR]=$0; depths[NR]=depth
            }
            END {
                target=depths[cursor]
                for (i=cursor;i>=1;i--) {
                    if (depths[i]==target-1) { print i; exit }
                }
                print 1
            }
        ')"
        # Find the matching closing brace
        node_end="$(printf '%s' "$text" | awk -v start="$((node_start))" -v cursor="$((line + 1))" '
            NR < start { next }
            { for (i=1;i<=length($0);i++) { c=substr($0,i,1); if(c=="{") d++; else if(c=="}") { d--; if(d<0){print NR; exit} } } }
        ')"
        [[ -z "$node_end" ]] && node_end="$total_lines"
        # Extract compatible from within current node block
        compat="$(printf '%s' "$text" | sed -n "${node_start},${node_end}p" | grep -oP 'compatible\s*=\s*"\K[^"]+' | head -1)" || compat=""
        # Fall back to ancestor walk only if current node has no compatible
        [[ -z "$compat" ]] && { compat="$(node_compatible_at "$text" "$line")" || compat=""; }
        if [[ -n "$compat" ]]; then
            _add_binding_items items "$compat" "$BINDINGS_DIR"
        fi
    fi

    local items_json first i
    first=1
    items_json="["
    for i in "${items[@]:-}"; do
        [[ -z "$i" ]] && continue
        [[ $first -eq 0 ]] && items_json="${items_json},"
        items_json="${items_json}${i}"
        first=0
    done
    items_json="${items_json}]"
    send "$(jq -n --argjson id "$id" --argjson items "$items_json" '{"jsonrpc":"2.0","id":$id,"result":{"isIncomplete":false,"items":$items}}')"
}


# Append binding property completion items to an array variable.
# Usage: _add_binding_items items_varname compat bindings_dir
_add_binding_items() {
    local -n _items_ref="$1"
    local compat="$2" bindings_dir="$3"
    [[ -z "$compat" ]] && return 0
    local binding_file=""
    binding_file="$(rg -l "$compat" --glob='*.yaml' "$bindings_dir" 2>/dev/null | sort_binding_files_for_compat "$compat" | head -1)" || binding_file=""
    [[ -z "$binding_file" ]] && return 0
    local bname prop
    bname="$(basename "$binding_file")"
    while IFS= read -r prop; do
        [[ -z "$prop" ]] && continue
        _items_ref+=("$(jq -n --arg l "$prop" --arg d "From binding: $bname" '{"label":$l,"kind":10,"detail":$d}')")
    done < <(_get_binding_props "$binding_file")
}


