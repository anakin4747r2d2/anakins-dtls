KASLR_SEED_DOC='## kaslr-seed

Property name: `kaslr-seed`

Value type: `<u64>`

A 64-bit value used to seed the kernel address space layout randomization (KASLR). The value should be a cryptographically random number provided by firmware.'

# ---------------------------------------------------------------------------
# Hover dispatch
# ---------------------------------------------------------------------------

# Global variables set during initialize
BINDINGS_DIR=""
SPEC_DIR=""
LINUX_DIR=""
INCLUDE_DIRS=()

# ---------------------------------------------------------------------------
# CPP macro helpers
# ---------------------------------------------------------------------------

# Given a macro name, the document text, and the root path, return
# "header_rel_path:define_line" for the first matching #define, or empty.
# Search for a #define of macro in a single header file. Returns "file:line" or empty.
_search_macro_in_header() {
    local macro="$1" header_file="$2"
    [[ -f "$header_file" ]] || return 0
    local lineno
    lineno="$(grep -n "^#define ${macro}[[:space:]]" "$header_file" 2>/dev/null | head -1 | cut -d: -f1)" || true
    [[ -z "$lineno" ]] && return 0
    printf '%s:%s' "$header_file" "$lineno"
}

find_macro_location() {
    local macro="$1" doc_text="$2"
    [[ -n "$macro" ]] || return 0
    [[ ${#INCLUDE_DIRS[@]} -gt 0 ]] || return 0

    # Extract #include <...> paths from the document
    local includes
    includes="$(printf '%s' "$doc_text" | grep -o '#include <[^>]*>' | sed 's/#include <//;s/>//')" || true
    [[ -n "$includes" ]] || return 0

    local inc_path dir header_file result
    while IFS= read -r inc_path; do
        [[ -n "$inc_path" ]] || continue
        for dir in "${INCLUDE_DIRS[@]}"; do
            header_file="${dir}/${inc_path}"
            result="$(_search_macro_in_header "$macro" "$header_file")"
            [[ -n "$result" ]] || continue
            printf '%s' "$result"
            return 0
        done
    done <<< "$includes"
    return 0
}

# Given a macro name and doc_text, return a markdown hover string or empty.
find_macro_doc() {
    local macro="$1" doc_text="$2"
    local location
    location="$(find_macro_location "$macro" "$doc_text")"
    [[ -n "$location" ]] || return 0

    local header_file lineno define_line inc_rel
    header_file="${location%:*}"
    lineno="${location##*:}"
    define_line="$(sed -n "${lineno}p" "$header_file")"
    # Make header path relative to include root for display
    inc_rel="$header_file"
    for dir in "${INCLUDE_DIRS[@]}"; do
        if [[ "$header_file" == "${dir}/"* ]]; then
            inc_rel="${header_file#${dir}/}"
            break
        fi
    done

    printf '## %s\n\n**Defined in:** `%s`\n\n```c\n%s\n```' \
        "$macro" "$inc_rel" "$define_line"
}

# ---------------------------------------------------------------------------
# Definition helpers
# ---------------------------------------------------------------------------

# Scan line_text for a quoted string that contains the cursor.
# strict=1: cursor strictly between quotes; strict=0: cursor on or between quotes.
_quoted_string_at_char() {
    local line_text="$1" character="$2" strict="$3"
    local len=${#line_text} i=0 in_quote=0 start=0 ch
    while [[ $i -lt $len ]]; do
        ch="${line_text:$i:1}"
        if [[ "$ch" == '"' && $in_quote -eq 0 ]]; then
            in_quote=1; start=$i
        elif [[ "$ch" == '"' && $in_quote -ne 0 ]]; then
            in_quote=0
            [[ ($strict -eq 1 && $character -gt $start && $character -le $i) || \
               ($strict -eq 0 && $character -ge $start && $character -le $i) ]] || continue
            printf '%s' "${line_text:$((start+1)):$((i-start-1))}"
            return 0
        fi
        (( i++ )) || true
    done
    return 0
}

# Check if the cursor is on a quoted string within a compatible = ... line.
# Outputs the compatible value string (without quotes) or empty.
compatible_value_at() {
    local text="$1" line="$2" character="$3"
    local line_text
    line_text="$(printf '%s' "$text" | sed -n "$((line + 1))p")"
    printf '%s' "$line_text" | grep -q 'compatible[[:space:]]*=' || return 0
    # Try strict match first (cursor inside quotes), then loose (cursor on quote)
    local result
    result="$(_quoted_string_at_char "$line_text" "$character" 1)"
    [[ -n "$result" ]] && { printf '%s' "$result"; return 0; }
    _quoted_string_at_char "$line_text" "$character" 0
}

# Send a definition Location response.
send_definition() {
    local id="$1" file_path="$2" file_line="$3" char_col="${4:-0}"
    send "$(jq -n \
        --argjson id "$id" \
        --arg uri "file://$file_path" \
        --argjson line "$file_line" \
        --argjson col "$char_col" \
        '{"jsonrpc":"2.0","id":$id,"result":{"uri":$uri,"range":{"start":{"line":$line,"character":$col},"end":{"line":$line,"character":$col}}}}')"
}

# Find property definition in binding file or its $ref'd files. Returns "file:line" or empty.
_find_prop_in_binding() {
    local prop="$1" binding_file="$2"
    local prop_line
    prop_line="$(grep -n "^  ${prop}:" "$binding_file" 2>/dev/null | head -1 | cut -d: -f1)" || true
    if [[ -n "$prop_line" ]]; then
        printf '%s:%s' "$binding_file" "$prop_line"
        return 0
    fi
    # Follow $ref one level deep
    local ref_line ref_file abs_ref
    while IFS= read -r ref_line; do
        ref_file="$(printf '%s' "$ref_line" | grep -o '\$ref:[^#]*\.yaml' | sed 's/\$ref:[[:space:]]*//')"
        [[ -z "$ref_file" ]] && continue
        abs_ref="$(find "$BINDINGS_DIR" -name "$(basename "$ref_file")" 2>/dev/null | sort | head -1)"
        [[ -z "$abs_ref" ]] && continue
        prop_line="$(grep -n "^  ${prop}:" "$abs_ref" 2>/dev/null | head -1 | cut -d: -f1)" || true
        [[ -z "$prop_line" ]] && continue
        printf '%s:%s' "$abs_ref" "$prop_line"
        return 0
    done < <(grep '\$ref:' "$binding_file")
    return 0
}

# phandle_ref_at <text> <line> <character>
# If cursor is on a &label reference, return the label name.
phandle_ref_at() {
    local text="$1" line="$2" character="$3"
    local line_text
    line_text="$(printf '%s' "$text" | sed -n "$((line + 1))p")"
    # Extract all &word tokens and their positions, find the one spanning cursor
    printf '%s' "$line_text" | awk -v cursor="$character" '
        {
            pos = 0
            while (match(substr($0, pos+1), /&[A-Za-z_][A-Za-z0-9_]*/) ) {
                start = pos + RSTART - 1
                token = substr($0, pos + RSTART, RLENGTH)
                end = start + RLENGTH
                if (cursor >= start && cursor < end) {
                    sub(/^&/, "", token)
                    print token
                    exit
                }
                pos = pos + RSTART + RLENGTH - 1
            }
        }
    '
}

# find_label_line <text> <label>
# Return the 1-indexed line number of "label:" definition in text.
find_label_line() {
    local text="$1" label="$2"
    printf '%s' "$text" | grep -n "^[[:space:]]*${label}:" | head -1 | cut -d: -f1
}

# find_includers_of <target_file> <search_dir> <visited_file> [cleanup]
# Find all files that (transitively) include target_file.
# Writes matching file paths to stdout.
find_includers_of() {
    local target="$1" search_dir="$2" visited="${3:-$(mktemp)}" cleanup="${4:-1}"
    local basename_target
    basename_target="$(basename "$target")"
    grep -qxF "$target" "$visited" 2>/dev/null && { [[ $cleanup -eq 1 ]] && rm -f "$visited"; return; }
    printf '%s\n' "$target" >> "$visited"
    # Find files that include this file by basename (handles both #include and /include/)
    while IFS= read -r includer; do
        printf '%s\n' "$includer"
        find_includers_of "$includer" "$search_dir" "$visited" 0 || true
    done < <(rg -l "(#include|/include/)[[:space:]]*\"[^\"]*${basename_target}\"" --glob '*.dts' --glob '*.dtsi' "$search_dir" 2>/dev/null || true)
    [[ $cleanup -eq 1 ]] && rm -f "$visited"
}

# find_label_in_includes <label> <current_file> [visited_file] [cleanup]
# Search #include'd .dts/.dtsi files recursively for a label definition.
# Returns "file:line_number" (1-indexed) or empty. Uses a visited-file set to
# prevent infinite loops from circular includes.
find_label_in_includes() {
    local label="$1" current_file="$2"
    local visited_file="${3:-$(mktemp)}"
    local _cleanup="${4:-1}"

    [[ -f "$current_file" ]] || return 1
    grep -qxF "$current_file" "$visited_file" 2>/dev/null && return 1
    printf '%s\n' "$current_file" >> "$visited_file"

    local current_dir
    current_dir="$(dirname "$current_file")"

    while IFS= read -r inc_path; do
        local abs_path
        [[ "$inc_path" = /* ]] && abs_path="$inc_path" || abs_path="${current_dir}/${inc_path}"
        [[ -f "$abs_path" ]] || continue

        local line_num
        line_num="$(grep -n "^[[:space:]]*${label}:" "$abs_path" | head -1 | cut -d: -f1)"
        if [[ -n "$line_num" ]]; then
            [[ "$_cleanup" == "1" ]] && rm -f "$visited_file"
            printf '%s:%s' "$abs_path" "$line_num"
            return 0
        fi

        local result
        result="$(find_label_in_includes "$label" "$abs_path" "$visited_file" 0)"
        if [[ -n "$result" ]]; then
            [[ "$_cleanup" == "1" ]] && rm -f "$visited_file"
            printf '%s' "$result"
            return 0
        fi
    done < <({ grep -oP '(?<=["\x27])[^"\x27]+\.dtsi(?=["\x27])' "$current_file" 2>/dev/null; grep -oP '(?<=["\x27])[^"\x27]+\.dts(?=["\x27])' "$current_file" 2>/dev/null; } | sort -u)

    [[ "$_cleanup" == "1" ]] && rm -f "$visited_file"
    return 1
}

# Resolve &label to definition location in the same file.
# Outputs "file:line:col" or nothing.
_def_phandle_in_file() {
    local text="$1" label="$2" uri="$3"
    local label_line label_line_text label_col
    label_line="$(find_label_line "$text" "$label")" || label_line=""
    [[ -z "$label_line" ]] && return 0
    label_line_text="$(printf '%s' "$text" | sed -n "${label_line}p")"
    label_col="$(printf '%s' "$label_line_text" | grep -bo "${label}:" | head -1 | cut -d: -f1)" || label_col=0
    label_line=$(( label_line - 1 ))
    printf '%s:%s:%s' "${uri#file://}" "$label_line" "${label_col:-0}"
}

# Resolve &label to definition location across included files.
# Outputs "file:line:col" or nothing.
_def_phandle_cross_file() {
    local label="$1" file_path="$2"
    local cross_result cross_file cross_line cross_line_text cross_col
    cross_result="$(find_label_in_includes "$label" "$file_path")" || cross_result=""
    [[ -z "$cross_result" ]] && return 0
    cross_file="${cross_result%:*}"
    cross_line="${cross_result##*:}"
    cross_line_text="$(sed -n "${cross_line}p" "$cross_file" 2>/dev/null)"
    cross_col="$(printf '%s' "$cross_line_text" | grep -bo "${label}:" | head -1 | cut -d: -f1)" || cross_col=0
    cross_line=$(( cross_line - 1 ))
    [[ $cross_line -lt 0 ]] && cross_line=0
    printf '%s:%s:%s' "$cross_file" "$cross_line" "${cross_col:-0}"
}

# def_by_phandle <id> <text> <line> <char> <uri>
# Returns 0 and sends result if cursor is on a phandle reference.
def_by_phandle() {
    local def_id="$1" def_text="$2" def_line="$3" def_char="$4" def_uri="$5"
    local phandle_label
    phandle_label="$(phandle_ref_at "$def_text" "$def_line" "$def_char")" || phandle_label=""
    [[ -z "$phandle_label" ]] && return 1
    local loc
    loc="$(_def_phandle_in_file "$def_text" "$phandle_label" "$def_uri")"
    [[ -z "$loc" ]] && loc="$(_def_phandle_cross_file "$phandle_label" "${def_uri#file://}")"
    [[ -z "$loc" ]] && return 1
    local d_file d_line d_col
    d_file="${loc%%:*}"; loc="${loc#*:}"
    d_line="${loc%%:*}"; d_col="${loc##*:}"
    send_definition "$def_id" "$d_file" "$d_line" "${d_col:-0}"
}

# def_by_compatible_value <id> <text> <line> <char>
# Returns 0 and sends result if cursor is on a compatible string value.
def_by_compatible_value() {
    local def_id="$1" def_text="$2" def_line="$3" def_char="$4"
    [[ -z "$BINDINGS_DIR" ]] && return 1
    local compat_val
    compat_val="$(compatible_value_at "$def_text" "$def_line" "$def_char")"
    [[ -z "$compat_val" ]] && return 1
    local binding_file file_line
    binding_file="$(rg -l "$compat_val" --glob '*.yaml' "$BINDINGS_DIR" 2>/dev/null | sort_binding_files_for_compat "$compat_val" | head -1)" || true
    [[ -z "$binding_file" ]] && return 1
    file_line="$(grep -n "$compat_val" "$binding_file" 2>/dev/null | head -1 | cut -d: -f1)" || true
    file_line=$(( file_line - 1 ))
    [[ $file_line -lt 0 ]] && file_line=0
    send_definition "$def_id" "$binding_file" "$file_line"
}

# def_by_macro <id> <word> <text>
# Returns 0 and sends result if word is a CPP macro.
def_by_macro() {
    local def_id="$1" def_word="$2" def_text="$3"
    [[ "$def_word" =~ ^[A-Z][A-Z0-9_]*$ ]] || return 1
    local macro_loc mfile mline
    macro_loc="$(find_macro_location "$def_word" "$def_text")"
    [[ -z "$macro_loc" ]] && return 1
    mfile="${macro_loc%:*}"
    mline=$(( ${macro_loc##*:} - 1 ))
    [[ $mline -lt 0 ]] && mline=0
    send_definition "$def_id" "$mfile" "$mline"
}

# def_by_spec <id> <word>
# Returns 0 and sends result if word has a spec RST section.
def_by_spec() {
    local def_id="$1" def_word="$2"
    [[ -z "$SPEC_DIR" ]] && return 1
    local spec_result spec_file spec_line
    spec_result="$(rg -n "^${def_word}$|^\`\`/${def_word}\`\`|^.. _sect-standard-properties-${def_word}:" "$SPEC_DIR" 2>/dev/null | head -1)" || true
    [[ -z "$spec_result" ]] && return 1
    spec_file="$(printf '%s' "$spec_result" | cut -d: -f1)"
    spec_line=$(( $(printf '%s' "$spec_result" | cut -d: -f2) - 1 ))
    [[ $spec_line -lt 0 ]] && spec_line=0
    send_definition "$def_id" "$spec_file" "$spec_line"
}

# def_by_binding_prop <id> <word> <text> <line>
# Returns 0 and sends result if word is a property in the node's binding.
def_by_binding_prop() {
    local def_id="$1" def_word="$2" def_text="$3" def_line="$4"
    [[ -z "$BINDINGS_DIR" ]] && return 1
    local node_compat
    node_compat="$(node_compatible_at "$def_text" "$def_line")"
    [[ -z "$node_compat" ]] && return 1
    local binding_file location prop_file prop_line
    while IFS= read -r binding_file; do
        location="$(_find_prop_in_binding "$def_word" "$binding_file")"
        [[ -z "$location" ]] && continue
        prop_file="${location%:*}"
        prop_line=$(( ${location##*:} - 1 ))
        [[ $prop_line -lt 0 ]] && prop_line=0
        send_definition "$def_id" "$prop_file" "$prop_line"
        return 0
    done < <(rg -l "$node_compat" --glob '*.yaml' "$BINDINGS_DIR" 2>/dev/null | sort_binding_files_for_compat "$node_compat")
    return 1
}

# def_by_global_prop <id> <word>
# Returns 0 and sends result if word is a property in any binding YAML.
def_by_global_prop() {
    local def_id="$1" def_word="$2"
    [[ -z "$BINDINGS_DIR" ]] && return 1
    local global_file global_line
    while IFS= read -r global_file; do
        global_line="$(grep -n "^  ${def_word}:" "$global_file" | head -1 | cut -d: -f1)"
        [[ -z "$global_line" ]] && continue
        global_line=$(( global_line - 1 ))
        send_definition "$def_id" "$global_file" "$global_line"
        return 0
    done < <(rg -l "^  ${def_word}:" --glob '*.yaml' "$BINDINGS_DIR" 2>/dev/null | sort_binding_files_for_compat "$def_word" | head -5)
    return 1
}

handle_definition() {
    local body="$1"
    local def_uri def_line def_char def_id def_text
    def_uri=$(printf '%s' "$body" | jq -r '.params.textDocument.uri')
    def_line=$(printf '%s' "$body" | jq -r '.params.position.line')
    def_char=$(printf '%s' "$body" | jq -r '.params.position.character')
    def_id=$(printf '%s' "$body" | jq -r '.id')
    def_text="${DOC_TEXT[$def_uri]:-}"
    [[ -z "$def_text" ]] && { send_null "$def_id"; return; }

    local def_word
    def_word="$(word_at "$def_text" "$def_line" "$def_char")"

    def_by_phandle        "$def_id" "$def_text" "$def_line" "$def_char" "$def_uri" && return
    def_by_compatible_value "$def_id" "$def_text" "$def_line" "$def_char"         && return
    def_by_macro           "$def_id" "$def_word" "$def_text"                        && return
    [[ -z "$def_word" ]] && { send_null "$def_id"; return; }
    def_by_spec            "$def_id" "$def_word"                                    && return
    def_by_binding_prop    "$def_id" "$def_word" "$def_text" "$def_line"            && return
    def_by_global_prop     "$def_id" "$def_word"                                    && return
    send_null "$def_id"
}

# ---------------------------------------------------------------------------
# Extract the compatible string of the node enclosing the given line.
# sort_binding_files_for_compat <compat>
# Reads file paths from stdin, sorts so files whose path contains
# a component of the compatible string come first.
sort_binding_files_for_compat() {
    local compat="$1"
    awk -v compat="$compat" '{
        n = split(compat, parts, /[,\/\.\-]/)
        score = 9
        for (i = 1; i <= n; i++) {
            if (length(parts[i]) > 2 && index($0, parts[i]) > 0) { score = 1; break }
        }
        base = $0; gsub(/.*\//, "", base); gsub(/\.yaml$/, "", base)
        if (base == compat) score = 0
        print score "\t" $0
    }' | sort | cut -f2
}

node_compatible_at() {
    local text="$1" line="$2"
    local above
    above="$(printf '%s' "$text" | head -n "$((line + 1))")" || true
    # Walk backwards through all lines above, tracking brace depth, to find the
    # nearest ancestor node that has a compatible property.
    printf '%s' "$above" | awk '
        {
            # Track brace depth cumulatively
            for (i = 1; i <= length($0); i++) {
                c = substr($0, i, 1)
                if (c == "{") depth++
                else if (c == "}") depth--
            }
            lines[NR] = $0
            depths[NR] = depth
        }
        END {
            target_depth = depth
            for (i = NR; i >= 1; i--) {
                if (depths[i] <= target_depth && lines[i] ~ /compatible[[:space:]]*=/) {
                    match(lines[i], /"[^"]*"/)
                    if (RSTART) {
                        val = substr(lines[i], RSTART+1, RLENGTH-2)
                        print val
                        exit
                    }
                }
            }
        }
    ' || true
}

# Resolve phandle label to its node compatible string.
# Searches the current text and then cross-file includes.
_phandle_label_compat() {
    local text="$1" label="$2" cur_file="$3"
    local lbl_line
    lbl_line="$(find_label_line "$text" "$label")" || lbl_line=""
    if [[ -n "$lbl_line" ]]; then
        node_compatible_at "$text" "$lbl_line" || true
        return 0
    fi
    local cross_result
    cross_result="$(find_label_in_includes "$label" "$cur_file")" || cross_result=""
    [[ -z "$cross_result" ]] && return 0
    local phandle_file phandle_line_num phandle_text
    phandle_file="${cross_result%:*}"
    phandle_line_num=$(( ${cross_result##*:} ))
    phandle_text="$(cat "$phandle_file" 2>/dev/null)"
    node_compatible_at "$phandle_text" "$phandle_line_num" || true
}

# Return compatible hover doc for a phandle reference at cursor, or empty.
_hover_for_phandle_ref() {
    local text="$1" line="$2" character="$3" bindings_dir="$4"
    local phandle_lbl
    phandle_lbl="$(phandle_ref_at "$text" "$line" "$character")" || phandle_lbl=""
    [[ -z "$phandle_lbl" ]] && return 0
    local cur_file="${uri#file://}"
    local phandle_compat
    phandle_compat="$(_phandle_label_compat "$text" "$phandle_lbl" "$cur_file")" || phandle_compat=""
    [[ -z "${phandle_compat:-}" ]] && return 0
    find_compatible_value_hover "$phandle_compat" "$bindings_dir" || true
}

extract_property_doc() {
    local prop="$1" yaml_file="$2"
    awk -v prop="$prop" '
        /^properties:/ { in_props=1; next }
        in_props && /^[^ ]/ && !/^  / { in_props=0 }
        in_props && match($0, "^  "prop":") { in_prop=1; next }
        in_prop {
            if (match($0, "^  [^ ]")) { in_prop=0; next }
            if (match($0, "^    description:")) {
                in_desc=1
                sub(/^    description:[[:space:]]*[|>]?[[:space:]]*/, "", $0)
                if (length($0) > 0) desc=$0
                next
            }
            if (in_desc) {
                if (match($0, "^      ")) {
                    sub(/^      /, "", $0)
                    if (length(desc) > 0) desc=desc "\n" $0
                    else desc=$0
                } else {
                    in_desc=0
                }
            }
        }
        END { print desc }
    ' "$yaml_file" | sed '/^[[:space:]]*$/d' | head -20
}

# extract_property_doc_recursive <prop> <yaml_file> <depth>
# Like extract_property_doc but follows $ref chains up to 3 levels deep.
extract_property_doc_recursive() {
    local prop="$1" yaml_file="$2" depth="${3:-0}"
    [[ $depth -gt 3 ]] && return 1
    local doc
    doc="$(extract_property_doc "$prop" "$yaml_file")"
    [[ -n "$doc" ]] && { printf '%s' "$doc"; return 0; }
    # Follow $ref links
    local ref_line ref_name abs_ref
    while IFS= read -r ref_line; do
        ref_name="$(printf '%s' "$ref_line" | grep -o '\$ref:[^#"]*\.yaml' | sed 's/\$ref:[[:space:]]*//')"
        [[ -z "$ref_name" ]] && continue
        abs_ref="$(find "${BINDINGS_DIR:-$(dirname "$yaml_file")}" -name "$(basename "$ref_name")" 2>/dev/null | sort | head -1)"
        [[ -z "$abs_ref" ]] && continue
        doc="$(extract_property_doc_recursive "$prop" "$abs_ref" $((depth + 1)))"
        [[ -n "$doc" ]] && { printf '%s' "$doc"; return 0; }
    done < <(grep '\$ref:' "$yaml_file" 2>/dev/null)
    return 1
}

# Search ALL binding YAML files for a property definition.
find_property_in_any_binding() {
    local prop="$1" bindings_dir="$2"
    [[ -d "$bindings_dir" ]] || return 1
    [[ -n "$prop" ]] || return 1
    local yaml_file doc
    while IFS= read -r yaml_file; do
        doc="$(extract_property_doc "$prop" "$yaml_file")"
        [[ -n "$doc" ]] && { printf '%s' "$doc"; return 0; }
    done < <(rg -l "^  ${prop}:" "$bindings_dir" --glob '*.yaml' 2>/dev/null | sort | head -5)
    return 1
}

# Given a compatible string, a property name, and the bindings directory,
# return the property description from the matching binding YAML file.
# Follows $ref includes up to 3 levels deep.
find_binding_doc() {
    local compatible="$1" prop="$2" bindings_dir="$3"
    [[ -d "$bindings_dir" ]] || return 0
    [[ -n "$compatible" ]] || return 0
    [[ -n "$prop" ]] || return 0

    local file doc
    while IFS= read -r file; do
        doc="$(extract_property_doc_recursive "$prop" "$file" 0)"
        if [[ -n "$doc" ]]; then
            printf '%s' "$doc"
            return 0
        fi
    done < <(rg -l "$compatible" --glob '*.yaml' "$bindings_dir" 2>/dev/null | sort_binding_files_for_compat "$compatible")
    return 0
}

# Given a compatible value string and the bindings directory,
# return a markdown hover doc for the binding itself.
find_compatible_value_hover() {
    local compat_val="$1" bindings_dir="$2"
    [[ -n "$compat_val" ]] || return 0
    [[ -d "$bindings_dir" ]] || return 0

    # Try patterns from most-specific to least-specific to find the canonical binding
    local binding_file
    # 1. const: <compat> (exact const match)
    binding_file="$(rg -l "^[[:space:]]+const: ${compat_val}$" --glob '*.yaml' "$bindings_dir" 2>/dev/null | sort_binding_files_for_compat "$compat_val" | head -1)" || true
    # 2. enum entry: "- <compat>" (exact enum entry)
    if [[ -z "$binding_file" ]]; then
        binding_file="$(rg -l "^      - ${compat_val}$" --glob '*.yaml' "$bindings_dir" 2>/dev/null | sort | head -1)" || true
    fi
    # 3. Fallback: any occurrence
    if [[ -z "$binding_file" ]]; then
        binding_file="$(rg -l "${compat_val}" --glob '*.yaml' "$bindings_dir" 2>/dev/null | sort | head -1)" || true
    fi
    [[ -z "$binding_file" ]] && return 0

    local desc
    desc="$(awk '/^description:/{found=1; next} found && /^[a-zA-Z$]/{exit} found{print}' "$binding_file" | sed '/^[[:space:]]*$/d' | sed 's/^  //')"
    # Fall back to title: if no description:
    if [[ -z "$desc" ]]; then
        desc="$(awk '/^title:/{sub(/^title:[[:space:]]*/,""); print; exit}' "$binding_file")"
    fi
    [[ -z "$desc" ]] && return 0

    local rel_path
    rel_path="${binding_file#${bindings_dir}/}"

    printf '## %s\n\n**Binding:** `%s`\n\n%s' "$compat_val" "$rel_path" "$desc"
}

# Search Linux kernel Documentation .txt binding files for a property.
find_doc_in_txt_bindings() {
    local prop="$1" linux_dir="$2"
    local doc_dir="$linux_dir/Documentation/devicetree"
    [[ -d "$doc_dir" ]] || return 1
    local txt_file
    txt_file="$(rg -l "^[[:space:]]*-[[:space:]]+${prop}[[:space:]]*:|^${prop}[[:space:]]+(is|are|property|specifies|contains|should|optional|required|phandle)" "$doc_dir" --glob '*.txt' 2>/dev/null | sort | head -1)"
    [[ -z "$txt_file" ]] && return 1
    awk -v prop="$prop" '
        $0 ~ "^[[:space:]]*-[[:space:]]"prop"[[:space:]]*:|^"prop"[[:space:]]+(is|are|property|specifies|contains|should|optional|required|phandle)" { found=NR }
        found && NR > found && /^[[:space:]]*-[[:space:]][a-zA-Z#]/ { exit }
        found && NR >= found && NR <= found+10 { print }
    ' "$txt_file"
}

# Search Linux kernel Documentation for any mention of a DT property.
find_linux_doc_for_prop() {
    local prop="$1" linux_dir="$2"
    [[ -n "$linux_dir" ]] || return 1
    [[ "$prop" =~ ^[a-zA-Z#][a-zA-Z0-9#_,-]*$ ]] || return 1
    local result
    result="$(find_doc_in_txt_bindings "$prop" "$linux_dir")"
    [[ -n "$result" ]] && { printf '%s' "$result"; return 0; }
    return 1
}

handle_hover() {
    local id="$1" text="$2" line="$3" character="$4"
    local word standard_doc compat binding_doc
    word="$(word_at "$text" "$line" "$character")"
    standard_doc=""

    case "$word" in
        compatible)              standard_doc="$COMPATIBLE_DOC" ;;
        model)                   standard_doc="$MODEL_DOC" ;;
        device_type)             standard_doc="$DEVICE_TYPE_DOC" ;;
        status)                  standard_doc="$STATUS_DOC" ;;
        phandle)                 standard_doc="$PHANDLE_DOC" ;;
        linux,phandle)           standard_doc="$LINUX_PHANDLE_DOC" ;;
        label)                   standard_doc="$LABEL_DOC" ;;
        reg)                     standard_doc="$REG_DOC" ;;
        reg-names)               standard_doc="$REG_NAMES_DOC" ;;
        ranges)                  standard_doc="$RANGES_DOC" ;;
        dma-ranges)              standard_doc="$DMA_RANGES_DOC" ;;
        dma-coherent)            standard_doc="$DMA_COHERENT_DOC" ;;
        '#address-cells')        standard_doc="$ADDRESS_CELLS_DOC" ;;
        '#size-cells')           standard_doc="$SIZE_CELLS_DOC" ;;
        interrupts)              standard_doc="$INTERRUPTS_DOC" ;;
        interrupts-extended)     standard_doc="$INTERRUPTS_EXTENDED_DOC" ;;
        interrupt-parent)        standard_doc="$INTERRUPT_PARENT_DOC" ;;
        '#interrupt-cells')      standard_doc="$INTERRUPT_CELLS_DOC" ;;
        interrupt-controller)    standard_doc="$INTERRUPT_CONTROLLER_DOC" ;;
        wakeup-source)           standard_doc="$WAKEUP_SOURCE_DOC" ;;
        clocks)                  standard_doc="$CLOCKS_DOC" ;;
        clock-names)             standard_doc="$CLOCK_NAMES_DOC" ;;
        '#clock-cells')          standard_doc="$CLOCK_CELLS_DOC" ;;
        clock-frequency)         standard_doc="$CLOCK_FREQUENCY_DOC" ;;
        bus-frequency)           standard_doc="$BUS_FREQUENCY_DOC" ;;
        timebase-frequency)      standard_doc="$TIMEBASE_FREQUENCY_DOC" ;;
        resets)                  standard_doc="$RESETS_DOC" ;;
        reset-names)             standard_doc="$RESET_NAMES_DOC" ;;
        '#reset-cells')          standard_doc="$RESET_CELLS_DOC" ;;
        gpios)                   standard_doc="$GPIOS_DOC" ;;
        gpio-controller)         standard_doc="$GPIO_CONTROLLER_DOC" ;;
        '#gpio-cells')           standard_doc="$GPIO_CELLS_DOC" ;;
        gpio-ranges)             standard_doc="$GPIO_RANGES_DOC" ;;
        pinctrl-names)           standard_doc="$PINCTRL_NAMES_DOC" ;;
        dmas)                    standard_doc="$DMAS_DOC" ;;
        dma-names)               standard_doc="$DMA_NAMES_DOC" ;;
        '#dma-cells')            standard_doc="$DMA_CELLS_DOC" ;;
        power-domains)           standard_doc="$POWER_DOMAINS_DOC" ;;
        iommus)                  standard_doc="$IOMMUS_DOC" ;;
        msi-parent)              standard_doc="$MSI_PARENT_DOC" ;;
        '#msi-cells')            standard_doc="$MSI_CELLS_DOC" ;;
        aliases)                 standard_doc="$ALIASES_DOC" ;;
        chosen)                  standard_doc="$CHOSEN_DOC" ;;
        memory)                  standard_doc="$MEMORY_DOC" ;;
        reserved-memory)         standard_doc="$RESERVED_MEMORY_DOC" ;;
        cpus)                    standard_doc="$CPUS_DOC" ;;
        stdout-path)             standard_doc="$STDOUT_PATH_DOC" ;;
        bootargs)                standard_doc="$BOOTARGS_DOC" ;;
        initrd-start|'linux,initrd-start') standard_doc="$INITRD_START_DOC" ;;
        initrd-end|'linux,initrd-end')     standard_doc="$INITRD_END_DOC" ;;
        kaslr-seed)              standard_doc="$KASLR_SEED_DOC" ;;
        *)
            # pinctrl-N pattern
            if [[ "$word" =~ ^pinctrl-[0-9]+$ ]]; then
                standard_doc="$PINCTRL_0_DOC"
            fi
            ;;
    esac

    # Check if cursor is on a compatible value string (e.g. "regulator-fixed")
    if [[ -n "$BINDINGS_DIR" ]]; then
        local compat_val compat_hover
        compat_val="$(compatible_value_at "$text" "$line" "$character")"
        compat_hover="$([[ -n "$compat_val" ]] && find_compatible_value_hover "$compat_val" "$BINDINGS_DIR" || true)"
        if [[ -n "$compat_hover" ]]; then
            send_hover "$id" "$compat_hover"
            return
        fi
    fi

    # Check if cursor is on a phandle reference (&label)
    if [[ -n "$BINDINGS_DIR" ]]; then
        local phandle_hover
        phandle_hover="$(_hover_for_phandle_ref "$text" "$line" "$character" "$BINDINGS_DIR")" || phandle_hover=""
        if [[ -n "$phandle_hover" ]]; then
            send_hover "$id" "$phandle_hover"
            return
        fi
    fi

    # Binding-aware augmentation
    compat="$(node_compatible_at "$text" "$line")" || compat=""
    if [[ -n "$compat" ]] && [[ -n "$BINDINGS_DIR" ]]; then
        binding_doc="$(find_binding_doc "$compat" "$word" "$BINDINGS_DIR")"
    else
        binding_doc=""
    fi

    # Global fallback: search all binding YAMLs for the property
    if [[ -z "$binding_doc" ]] && [[ -n "$BINDINGS_DIR" ]]; then
        binding_doc="$(find_property_in_any_binding "$word" "$BINDINGS_DIR")" || binding_doc=""
    fi

    _send_hover_result "$id" "$word" "$standard_doc" "$binding_doc" "$compat" "$text"
}

# Dispatch hover result combining ALL available documentation sources.
_send_hover_result() {
    local id="$1" word="$2" standard_doc="$3" binding_doc="$4" compat="$5" text="$6"
    local NL=$'\n'
    local parts="" sep=""

    # 1. Standard DT spec doc
    if [[ -n "$standard_doc" ]]; then
        parts+="${sep}**Source:** [Device Tree Specification](https://devicetree-specification.readthedocs.io/)${NL}${NL}${standard_doc}"
        sep=$'\n\n---\n\n'
    fi

    # 2. Binding doc (from node compatible or global search)
    if [[ -n "$binding_doc" ]]; then
        local binding_source="**Source:** Linux kernel bindings"
        [[ -n "$compat" ]] && binding_source="**Source:** Linux kernel bindings (\`${compat}\`)"
        parts+="${sep}${binding_source}${NL}${NL}${binding_doc}"
        sep=$'\n\n---\n\n'
    fi

    # 3. CPP macro doc
    local macro_doc
    macro_doc="$(find_macro_doc "$word" "$text")" || macro_doc=""
    [[ -n "$macro_doc" ]] && { parts+="${sep}${macro_doc}"; sep=$'\n\n---\n\n'; }

    # 4. Linux kernel Documentation .txt
    local linux_doc
    linux_doc="$(find_linux_doc_for_prop "$word" "$LINUX_DIR")" || linux_doc=""
    if [[ -n "$linux_doc" ]]; then
        parts+="${sep}**Source:** Linux kernel Documentation${NL}${NL}\`\`\`${NL}${linux_doc}${NL}\`\`\`"
        sep=$'\n\n---\n\n'
    fi

    if [[ -n "$parts" ]]; then
        send_hover "$id" "$parts"
    else
        send_null "$id"
    fi
}

# ---------------------------------------------------------------------------
# ---------------------------------------------------------------------------
# Diagnostics
# ---------------------------------------------------------------------------

# publish_diagnostics <uri> <text>
# Send a textDocument/publishDiagnostics notification. Runs in background
# so the main loop remains responsive to incoming requests.
publish_diagnostics() {
    local uri="$1" text="$2"
    (
        local diagnostics
        diagnostics="$(collect_diagnostics "$text")"
        send "{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/publishDiagnostics\",\"params\":{\"uri\":${uri},\"diagnostics\":${diagnostics}}}"
    ) &
}

# ---------------------------------------------------------------------------
# Syntax diagnostic functions
# ---------------------------------------------------------------------------
collect_syntax_diagnostics() {
    local text="$1" known_compats="${2:-}"
    local -a raw_diags=()

    local depth=0 angle=0 lineno=0 last_open_line=0
    local -A seen_labels=()
    local -A prop_seen=()
    local -A addr_cells=()
    local -A size_cells=()
    local -A node_unit_addr=()
    local -A node_has_linux_phandle=() linux_phandle_lineno=() node_has_phandle=()
    local pending_unit_addr=""

    _dj_esc() {
        local s="${1//\\/\\\\}"
        s="${s//\"/\\\"}"
        printf '%s' "$s"
    }
    _dj_make() {
        local l=$1 sev=$2
        local msg; msg="$(_dj_esc "$3")"
        printf '{"range":{"start":{"line":%d,"character":0},"end":{"line":%d,"character":100}},"severity":%d,"message":"%s"}' \
            "$l" "$l" "$sev" "$msg"
    }
    _dj_make_line() {
        local l=$1 sev=$2 src_line="$4"
        local msg; msg="$(_dj_esc "$3")"
        local rest="$src_line" cs=0
        while [[ -n "$rest" && ("${rest:0:1}" == ' ' || "${rest:0:1}" == $'\t') ]]; do
            rest="${rest:1}"
            (( cs++ )) || true
        done
        local ce=${#src_line}
        [[ $ce -le $cs ]] && ce=$(( cs + ${#rest} ))
        printf '{"range":{"start":{"line":%d,"character":%d},"end":{"line":%d,"character":%d}},"severity":%d,"message":"%s"}' \
            "$l" "$cs" "$l" "$ce" "$sev" "$msg"
    }
    _dj_make_at() {
        local l=$1 sev=$2 cs=$4 ce=$5
        local msg; msg="$(_dj_esc "$3")"
        printf '{"range":{"start":{"line":%d,"character":%d},"end":{"line":%d,"character":%d}},"severity":%d,"message":"%s"}' \
            "$l" "$cs" "$l" "$ce" "$sev" "$msg"
    }
    # _first_quoted_range <line> → outputs "cs ce" or nothing
    _first_quoted_range() {
        local s="$1"
        local before="${s%%\"*}"
        [[ "$before" == "$s" ]] && return
        local cs=${#before}
        local rest="${s#*\"}"
        local inside="${rest%%\"*}"
        printf '%d %d' "$cs" $(( cs + ${#inside} + 2 ))
    }
    # Find column of first occurrence of substr in str
    _col_of() {
        local str="$1" sub="$2"
        local pfx="${str%%${sub}*}"
        printf '%d' "${#pfx}"
    }

    while IFS= read -r raw_line; do
        local line="$raw_line"

        # Strip // comments (only outside quoted strings)
        line="${line%% //*}"
        # Strip /* ... */ inline block comments
        while [[ "$line" == */\** && "$line" == *\*/* ]]; do
            local _lhs="${line%%/\**}"
            local _rhs="${line#*\*/}"
            line="${_lhs}${_rhs}"
        done

        # Track < > for multi-line value detection
        local _i _ch
        for (( _i=0; _i<${#line}; _i++ )); do
            _ch="${line:$_i:1}"
            if   [[ "$_ch" == '<' ]]; then (( angle++ )) || true
            elif [[ "$_ch" == '>' ]]; then (( angle > 0 )) && (( angle-- )) || true
            fi
        done

        # Continuation: trailing comma or open angle brackets
        local _tt="$line"
        while [[ -n "$_tt" && ("${_tt: -1}" == ' ' || "${_tt: -1}" == $'\t') ]]; do
            _tt="${_tt%?}"
        done
        local continuation=0
        [[ -n "$_tt" && "${_tt: -1}" == ',' ]] && continuation=1
        [[ $angle -gt 0 ]] && continuation=1

        # Missing semicolon on a property assignment line
        if [[ $continuation -eq 0 \
           && "$line" =~ ^[[:space:]]+([A-Za-z_#][A-Za-z0-9_,#-]*)[[:space:]]*= ]]; then
            local _pname="${BASH_REMATCH[1]}"
            # Check for missing semicolon AFTER saving the match
            if [[ ! "$line" =~ \;[[:space:]]*$ ]]; then
                local _pfx _cs _ce
                _pfx="${line%%${_pname}*}"
                _cs=${#_pfx}
                _ce=$(( _cs + ${#_pname} ))
                raw_diags+=( "$(_dj_make_at "$lineno" 1 "Missing semicolon" "$_cs" "$_ce")" )
            fi
        fi

        # Bare } without semicolon
        if [[ "$line" =~ ^[[:space:]]*\}[[:space:]]*$ ]]; then
            raw_diags+=( "$(_dj_make_line "$lineno" 1 "Missing semicolon: expected }; not }" "$raw_line")" )
        fi

        # Detect node unit-address BEFORE processing braces
        pending_unit_addr=""
        if [[ "$line" =~ [A-Za-z_][A-Za-z0-9_,-]*@([0-9a-fA-F]+)[[:space:]]*\{ ]]; then
            pending_unit_addr="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ [A-Za-z_][A-Za-z0-9_,-]*:[[:space:]]*[A-Za-z_][A-Za-z0-9_,-]*@([0-9a-fA-F]+) ]]; then
            pending_unit_addr="${BASH_REMATCH[1]}"
        fi

        # Process braces in document order
        local _bline="$line"
        while [[ "$_bline" =~ [\{\}] ]]; do
            local _bopen="${_bline%%\{*}"
            local _bclose="${_bline%%\}*}"
            local _bop=${#_bopen} _bcl=${#_bclose}
            if [[ $_bop -lt $_bcl ]]; then
                (( depth++ )) || true
                last_open_line="$lineno"
                addr_cells[$depth]="${addr_cells[$((depth-1))]:-}"
                size_cells[$depth]="${size_cells[$((depth-1))]:-}"
                local _k
                for _k in "${!prop_seen[@]}"; do
                    [[ "$_k" == "${depth}:"* ]] && unset "prop_seen[$_k]"
                done
                node_has_linux_phandle[$depth]=0
                node_has_phandle[$depth]=0
                node_unit_addr[$depth]="${pending_unit_addr:-}"
                pending_unit_addr=""
                _bline="${_bline:$((_bop+1))}"
            else
                if [[ $depth -gt 0 ]]; then
                    if [[ "${node_has_linux_phandle[$depth]:-0}" == 1 \
                       && "${node_has_phandle[$depth]:-0}" != 1 ]]; then
                        raw_diags+=( "$(_dj_make "${linux_phandle_lineno[$depth]:-0}" 4 \
                            "linux,phandle is deprecated — use phandle instead")" )
                    fi
                    local _k
                    for _k in "${!prop_seen[@]}"; do
                        [[ "$_k" == "${depth}:"* ]] && unset "prop_seen[$_k]"
                    done
                    unset "node_unit_addr[$depth]" || true
                    unset "addr_cells[$depth]" || true
                    unset "size_cells[$depth]" || true
                    (( depth-- )) || true
                else
                    raw_diags+=( "$(_dj_make_line "$lineno" 1 "Unbalanced brace: unexpected }" "$raw_line")" )
                fi
                _bline="${_bline:$((_bcl+1))}"
            fi
        done

        # Duplicate node label
        if [[ "$line" =~ ^[[:space:]]*([A-Za-z_][A-Za-z0-9_]*)[[:space:]]*: ]]; then
            local _lbl="${BASH_REMATCH[1]}"
            if [[ -n "${seen_labels[$_lbl]+x}" ]]; then
                raw_diags+=( "$(_dj_make_line "$lineno" 2 "Duplicate node label '$_lbl'" "$raw_line")" )
            else
                seen_labels[$_lbl]="$lineno"
            fi
        fi

        # Property-level diagnostics (inside a node)
        if [[ $depth -gt 0 \
           && "$line" =~ ^[[:space:]]+([A-Za-z_#][A-Za-z0-9_,#.-]*)([[:space:]]*=|;) ]]; then
            local _prop="${BASH_REMATCH[1]}"
            local _prop_key="${depth}:${_prop}"

            # Duplicate property
            if [[ -n "${prop_seen[$_prop_key]+x}" ]]; then
                local _dpfx _dcs _dce
                _dpfx="${line%%${_prop}*}"
                _dcs=${#_dpfx}
                _dce=$(( _dcs + ${#_prop} ))
                raw_diags+=( "$(_dj_make_at "$lineno" 2 "Duplicate property '$_prop' in node" "$_dcs" "$_dce")" )
            else
                prop_seen[$_prop_key]=1
            fi

            [[ "$_prop" == "phandle" ]] && node_has_phandle[$depth]=1
            if [[ "$_prop" == "linux,phandle" ]]; then
                node_has_linux_phandle[$depth]=1
                linux_phandle_lineno[$depth]="$lineno"
            fi

            # #address-cells / #size-cells
            if [[ "$_prop" == "#address-cells" && "$line" =~ \<([0-9]+)\> ]]; then
                addr_cells[$depth]="${BASH_REMATCH[1]}"
            fi
            if [[ "$_prop" == "#size-cells" && "$line" =~ \<([0-9]+)\> ]]; then
                size_cells[$depth]="${BASH_REMATCH[1]}"
            fi

            # status value check
            if [[ "$_prop" == "status" \
               && "$line" =~ status[[:space:]]*=[[:space:]]*\"([^\"]+)\" ]]; then
                local _sv="${BASH_REMATCH[1]}"
                if [[ "$_sv" != "okay" && "$_sv" != "disabled" && "$_sv" != "reserved" \
                   && "$_sv" != "fail" && "$_sv" != fail-* ]]; then
                    local _qcs _qce
                    read -r _qcs _qce <<< "$(_first_quoted_range "$line")"
                    raw_diags+=( "$(_dj_make_at "$lineno" 1 \
                        "Invalid status value '$_sv' -- must be okay, disabled, reserved, fail, or fail-sss" \
                        "${_qcs:-0}" "${_qce:-100}")" )
                fi
            fi

            # reg cell count mismatch and unit-addr check
            if [[ "$_prop" == "reg" \
               && "$line" =~ reg[[:space:]]*=[[:space:]]*\<([^\>]+)\> ]]; then
                local _reg_content="${BASH_REMATCH[1]}"
                local -a _reg_cells=()
                read -ra _reg_cells <<< "$_reg_content"
                local _ncells=${#_reg_cells[@]}
                local _pdepth _ac _sc
                _pdepth=$(( depth - 1 ))
                _ac="${addr_cells[$_pdepth]:-}"
                _sc="${size_cells[$_pdepth]:-}"
                if [[ -n "$_ac" && -n "$_sc" ]]; then
                    local _stride=$(( _ac + _sc ))
                    if [[ $_stride -gt 0 && $(( _ncells % _stride )) -ne 0 ]]; then
                        raw_diags+=( "$(_dj_make_line "$lineno" 2 \
                            "reg cell count ($_ncells) is not a multiple of #address-cells + #size-cells ($_ac+$_sc=$_stride)" \
                            "$raw_line")" )
                    fi
                fi
            fi

            # Node unit-address vs reg values
            if [[ "$_prop" == "reg" && -n "${node_unit_addr[$depth]:-}" ]]; then
                local _unit="${node_unit_addr[$depth]}"
                local _norm_unit
                _norm_unit="$(printf '%x' "0x$_unit" 2>/dev/null)" || _norm_unit=""
                if [[ -n "$_norm_unit" \
                   && "$line" =~ reg[[:space:]]*=[[:space:]]*\<([^\>]+)\> ]]; then
                    local _reg_part="${BASH_REMATCH[1]}"
                    local -a _ucells=()
                    read -ra _ucells <<< "$_reg_part"
                    local _matched=0 _ucell _norm_cell
                    for _ucell in "${_ucells[@]}"; do
                        _ucell="${_ucell//[^0-9a-fA-FxX]/}"
                        [[ -z "$_ucell" ]] && continue
                        _norm_cell="$(printf '%x' "$_ucell" 2>/dev/null)" || continue
                        if [[ "$_norm_unit" == "$_norm_cell" ]]; then
                            _matched=1
                            break
                        fi
                    done
                    if [[ $_matched -eq 0 && ${#_ucells[@]} -gt 0 ]]; then
                        raw_diags+=( "$(_dj_make_line "$lineno" 2 \
                            "Node unit-address (0x$_unit) does not match any reg cell value" \
                            "$raw_line")" )
                    fi
                fi
            fi

            # compatible format check
            if [[ "$_prop" == "compatible" \
               && "$line" =~ compatible[[:space:]]*=[[:space:]]*\"([^\"]+)\" ]]; then
                local _cv="${BASH_REMATCH[1]}"
                if [[ "$_cv" != "simple-bus" && "$_cv" != "simple-mfd" \
                   && "$_cv" != "fixed-clock" && "$_cv" != "regulator-fixed" \
                   && "$known_compats" != *"${_cv}|"* ]]; then
                    if [[ "$_cv" != *","* || "$_cv" =~ ^[A-Z] || "$_cv" == *" "* ]]; then
                        local _cqcs _cqce
                        read -r _cqcs _cqce <<< "$(_first_quoted_range "$line")"
                        raw_diags+=( "$(_dj_make_at "$lineno" 2 \
                            "compatible string '$_cv' should follow vendor,model format" \
                            "${_cqcs:-0}" "${_cqce:-100}")" )
                    fi
                fi
            fi
        fi

        (( lineno++ )) || true
    done <<< "$text"


    # 3c. /dts-v1/; missing
    local _has_nodes _has_dtsv1
    _has_nodes=$(printf '%s' "$text" | grep -cE '[A-Za-z_][A-Za-z0-9_,-]*[[:space:]]*@?[0-9a-fA-F]*[[:space:]]*\{' 2>/dev/null) || _has_nodes=0
    _has_dtsv1=$(printf '%s' "$text" | head -10 | grep -c '/dts-v1/;' 2>/dev/null) || _has_dtsv1=0
    if [[ ${_has_nodes:-0} -gt 0 && ${_has_dtsv1:-0} -eq 0 ]]; then
        raw_diags+=( "$(_dj_make 0 2 'Missing /dts-v1/; declaration')" )
    fi

    # 3a/3b. clock-names/clocks and gpio-names/gpios count mismatch
    local _diag_line_count
    _diag_line_count=$(printf '%s' "$text" | wc -l)
    if [[ ${_diag_line_count:-0} -le 500 ]]; then
    local _cnt_in=0 _clocks_v="" _cnames_v="" _gpios_v="" _gnames_v=""
    local _clocks_ln=0 _cnames_ln=0 _gpios_ln=0 _gnames_ln=0 _pline=0
    while IFS= read -r _pl; do
        local _ps="${_pl%%//*}"
        local _open_c _close_c
        _open_c=$(printf '%s' "$_ps" | tr -cd '{' | wc -c)
        _close_c=$(printf '%s' "$_ps" | tr -cd '}' | wc -c)
        (( _cnt_in += _open_c )) || true
        if [[ $_cnt_in -gt 0 ]]; then
            if [[ "$_ps" =~ ^[[:space:]]*clocks[[:space:]]*= ]]; then
                _clocks_v="$_ps"; _clocks_ln=$_pline
            fi
            if [[ "$_ps" =~ ^[[:space:]]*clock-names[[:space:]]*= ]]; then
                _cnames_v="$_ps"; _cnames_ln=$_pline
            fi
            if [[ "$_ps" =~ ^[[:space:]]*gpios[[:space:]]*= ]]; then
                _gpios_v="$_ps"; _gpios_ln=$_pline
            fi
            if [[ "$_ps" =~ ^[[:space:]]*gpio-names[[:space:]]*= ]]; then
                _gnames_v="$_ps"; _gnames_ln=$_pline
            fi
        fi
        if [[ $_close_c -gt 0 ]]; then
            (( _cnt_in -= _close_c )) || true
            [[ $_cnt_in -lt 0 ]] && _cnt_in=0
            if [[ $_cnt_in -eq 0 ]]; then
                if [[ -n "$_clocks_v" && -n "$_cnames_v" ]]; then
                    local _nclk _ncln
                    _nclk=$(printf '%s' "$_clocks_v" | grep -o '&' | wc -l) || _nclk=0
                    _ncln=$(printf '%s' "$_cnames_v" | grep -o '"' | wc -l) || _ncln=0
                    _ncln=$(( _ncln / 2 ))
                    if [[ $_nclk -ne $_ncln && $_nclk -gt 0 && $_ncln -gt 0 ]]; then
                        raw_diags+=( "$(_dj_make "$_cnames_ln" 2 "clock-names has ${_ncln} entries but clocks has ${_nclk} phandle pairs")" )
                    fi
                fi
                if [[ -n "$_gpios_v" && -n "$_gnames_v" ]]; then
                    local _ngpio _ngnam
                    _ngpio=$(printf '%s' "$_gpios_v" | grep -o '&' | wc -l) || _ngpio=0
                    _ngnam=$(printf '%s' "$_gnames_v" | grep -o '"' | wc -l) || _ngnam=0
                    _ngnam=$(( _ngnam / 2 ))
                    if [[ $_ngpio -ne $_ngnam && $_ngpio -gt 0 && $_ngnam -gt 0 ]]; then
                        raw_diags+=( "$(_dj_make "$_gnames_ln" 2 "gpio-names has ${_ngnam} entries but gpios has ${_ngpio} phandle pairs")" )
                    fi
                fi
                _clocks_v=""; _cnames_v=""; _gpios_v=""; _gnames_v=""
            fi
        fi
        (( _pline++ )) || true
    done <<< "$text"
    fi  # end 500-line guard

    if [[ $depth -gt 0 ]]; then
        raw_diags+=( "$(_dj_make "$last_open_line" 1 "Unbalanced brace: unclosed {")" )
    fi

    local _out="[" _first=1 _d
    for _d in "${raw_diags[@]}"; do
        [[ $_first -eq 1 ]] || _out+=","
        _out+="$_d"
        _first=0
    done
    _out+="]"
    printf '%s' "$_out"
}

# _parse_binding_nodes <text>
# Parse DTS node structure for binding diagnostics.
# Emits tab-separated: lineno\tcompat\tcol_start\tcol_end\tprop1\tprop2...
_parse_binding_nodes() {
    local text="$1"
    local depth=0 lineno=0
    local compat="" compat_line=0 compat_depth=0 compat_col_start=0 compat_col_end=0
    local -a all_props=()

    while IFS= read -r raw_line; do
        local line="$raw_line"
        line="${line%% //*}"

        # Track braces
        local _bl="$line"
        while [[ "$_bl" =~ [\{\}] ]]; do
            local _bo="${_bl%%\{*}" _bc="${_bl%%\}*}"
            local _bop=${#_bo} _bcp=${#_bc}
            if [[ $_bop -lt $_bcp ]]; then
                (( depth++ )) || true
                _bl="${_bl:$((_bop+1))}"
            else
                [[ $depth -gt 0 ]] && (( depth-- )) || true
                _bl="${_bl:$((_bcp+1))}"
            fi
        done

        # Detect compatible
        if [[ "$line" =~ compatible[[:space:]]*=[[:space:]]*\"([^\"]*)\" ]]; then
            local _cv="${BASH_REMATCH[1]}"
            compat="$_cv"
            compat_line=$lineno
            compat_depth=$depth
            # Find the quoted range
            local _before="${line%%\"*}"
            if [[ "$_before" != "$line" ]]; then
                compat_col_start=${#_before}
                local _rest="${line#*\"}"
                local _inside="${_rest%%\"*}"
                compat_col_end=$(( compat_col_start + ${#_inside} + 2 ))
            else
                compat_col_start=0
                compat_col_end=100
            fi
        fi

        # Collect properties at current depth (regardless of compatible order)
        if [[ $depth -gt 0 \
           && "$line" =~ ^[[:space:]]+([A-Za-z#][A-Za-z0-9_#,.-]*)([[:space:]]*=|;|[[:space:]]*$) ]]; then
            local _collected_prop="${BASH_REMATCH[1]}"
            [[ -n "$_collected_prop" ]] && all_props+=("${depth}:${_collected_prop}")
        fi

        # Emit record when depth drops below compat_depth
        if [[ -n "$compat" && $depth -lt $compat_depth ]]; then
            printf '%d\t%s\t%d\t%d' "$compat_line" "$compat" "$compat_col_start" "$compat_col_end"
            local _p _pd
            for _pd in "${all_props[@]:-}"; do
                _p="${_pd#*:}"
                [[ "${_pd%%:*}" == "$compat_depth" ]] && printf '\t%s' "$_p"
            done
            printf '\n'
            compat=""
            # clear props at this depth
            local -a _remaining=()
            for _pd in "${all_props[@]:-}"; do
                [[ "${_pd%%:*}" != "$compat_depth" ]] && _remaining+=("$_pd")
            done
            all_props=("${_remaining[@]:-}")
        fi

        (( lineno++ )) || true
    done <<< "$text"

    # Emit if compat is still open at EOF
    if [[ -n "$compat" ]]; then
        printf '%d\t%s\t%d\t%d' "$compat_line" "$compat" "$compat_col_start" "$compat_col_end"
        local _p _pd
        for _pd in "${all_props[@]:-}"; do
            _p="${_pd#*:}"
            [[ "${_pd%%:*}" == "$compat_depth" ]] && printf '\t%s' "$_p"
        done
        printf '\n'
    fi
}

