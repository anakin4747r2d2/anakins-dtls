#!/usr/bin/env bash
# shellcheck disable=SC2016
set -o errexit
set -o nounset
set -o pipefail

command -v jq > /dev/null || { printf 'anakins-dtls: jq is required but not found in PATH\n' >&2; exit 1; }

# Send a JSON-RPC message with a Content-Length header on stdout.
send() {
    local body="$1"
    local len _lock="/tmp/anakins-dtls-send-$$.lock"
    len="$(printf '%s' "$body" | wc -c)"
    while ! mkdir "$_lock" 2>/dev/null; do sleep 0.01; done
    printf "Content-Length: %d\r\n\r\n%s" "$len" "$body"
    rmdir "$_lock" 2>/dev/null || true
}

# Read one JSON-RPC message from stdin into BODY.
recv() {
    local line content_length=0

    while IFS= read -r line; do
        line="${line%$'\r'}"
        [[ -z "$line" ]] && break
        if [[ "$line" =~ ^Content-Length:\ ([0-9]+)$ ]]; then
            content_length="${BASH_REMATCH[1]}"
        fi
    done

    [[ "$content_length" -eq 0 ]] && return 1

    IFS= read -r -N "$content_length" BODY
}

# Return the whitespace-delimited token at the given line and character.
# Strips trailing =, ;, <, ", > so that "compatible = " returns "compatible".
word_at() {
    local text="$1" line="$2" character="$3"
    local line_text before after token word rest
    line_text="$(printf '%s' "$text" | sed -n "$((line + 1))p")"
    before="${line_text:0:$((character + 1))}"
    word="${before##*[$'\t =;<>\"@{']}"
    after="${line_text:${#before}}"
    rest="${after%%[$'\t =;<>\"@{']*}"
    token="${word}${rest}"
    # Strip any leading/trailing punctuation that snuck in
    token="${token%%[=;<>\"@{]*}"
    printf '%s' "$token"
}

# Send a hover response with a markdown value.
send_hover() {
    local id="$1" doc="$2"
    local value
    value="$(jq -cn --arg v "$doc" '$v')"
    send "{\"jsonrpc\":\"2.0\",\"id\":${id},\"result\":{\"contents\":{\"kind\":\"markdown\",\"value\":${value}}}}"
}

# Send a null result (no hover available).
send_null() {
    local id="$1"
    send "{\"jsonrpc\":\"2.0\",\"id\":${id},\"result\":null}"
}

